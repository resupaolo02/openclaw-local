# ──────────────────────────────────────────────
# OpenClaw Local — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the real .env to version control.
# ──────────────────────────────────────────────

# ═══════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════

# Primary LLM provider (Google Gemini)
# Get your API key at: https://aistudio.google.com/apikey
LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-3-flash-preview

# Context window size (in tokens) for the primary model
LLM_CTX_WINDOW=1000000

# Secondary LLM provider for coding tasks (OpenRouter)
# Get your API key at: https://openrouter.ai/keys
LLM_CODING_URL=https://openrouter.ai/api/v1/chat/completions
LLM_CODING_KEY=your-openrouter-api-key
LLM_CODING_MODEL=qwen/qwen3-coder:free

# ═══════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════

# CORS origin for the chat service (must match your public domain)
CORS_ORIGIN=https://your-domain.duckdns.org

# Traefik HTTP basic-auth credentials (protects all public routes)
# Generate with: htpasswd -nb username password
# Escape dollar signs by doubling them ($ → $$) for docker-compose
TRAEFIK_BASIC_AUTH=username:$$apr1$$HASH$$REST_OF_HASH

# ═══════════════════════════════════════════════
# DuckDNS (Dynamic DNS + Let's Encrypt TLS)
# ═══════════════════════════════════════════════

# DuckDNS token for automatic HTTPS certificate renewal
# Get yours at: https://www.duckdns.org/ (sign in, copy token)
DUCKDNS_TOKEN=your-duckdns-token
